{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",

    "ConnectionStrings": {
        "DefaultConnection": "Data Source=CineMatch.db"
    },

    "JwtSettings": {
        "Issuer": "CineMatchApi",
        "Audience": "CineMatchApiClient",
        "ExpireMinutes": 60
    }
}
